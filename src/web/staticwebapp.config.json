{
  "routes": [
    { "route": "/fn/*", "rewrite": "https://__FUNCTION_HOST__/api/*" }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [ "/fn/*" ]
  },
  "globalHeaders": {
    "/fn/*": {
      "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0"
    }
  }
}
