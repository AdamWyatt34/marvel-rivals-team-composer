{
  "routes": [
    {
      "route": "/fn/canary",
      "statusCode": 404
    },
    {
      "route": "/fn/*",
      "rewrite": "https://func-rivals-comp-dev.azurewebsites.net/api/*",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [ "/fn/*" ]
  }
}
