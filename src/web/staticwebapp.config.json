{
  "version": 1,
  "navigationFallback": { "rewrite": "/index.html", "exclude": ["/api/*", "/_next/*", "/*.js", "/*.css", "/*.png", "/*.jpg", "/*.svg", "/*.ico"] },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"],
      "rewrite": "https://__FUNCTION_HOST__/api"
    }
  ]
}
